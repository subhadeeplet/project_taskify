# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/taskify

# Secret used to sign JWT tokens (minimum 32 characters in production)
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# JWT token lifetime (e.g. 7d, 24h, 60m)
JWT_EXPIRES_IN=7d

# Port the API server listens on
PORT=3000

# Allowed frontend origin(s) for CORS — comma-separated for multiple URLs
# Single-server deploy: set to your live URL, e.g. https://taskify.example.com
FRONTEND_URL=http://localhost:5173

# Set to "production" when deploying
NODE_ENV=development

# Serve the built React app from the backend (auto-enabled when NODE_ENV=production)
SERVE_FRONTEND=false
