# Copy these into Railway → your service → Variables

NODE_ENV=production
SERVE_FRONTEND=true
JWT_EXPIRES_IN=7d

# Required — set in Railway dashboard (never commit real values)
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/taskify
JWT_SECRET=replace-with-a-long-random-string-at-least-32-characters

# Set AFTER generating your Railway public domain, e.g.:
# FRONTEND_URL=https://project-taskify-production.up.railway.app
FRONTEND_URL=
