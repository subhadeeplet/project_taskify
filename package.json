{
  "name": "taskify",
  "private": true,
  "scripts": {
    "install:all": "npm install --prefix FRONTEND && npm install --prefix BACKEND",
    "dev:backend": "npm run dev --prefix BACKEND",
    "dev:frontend": "npm run dev --prefix FRONTEND",
    "build": "npm run build --prefix FRONTEND",
    "start": "npm run start --prefix BACKEND",
    "start:prod": "npm run build && npm run start --prefix BACKEND",
    "typecheck": "npm run typecheck --prefix FRONTEND",
    "docker:build": "docker build -t taskify .",
    "docker:up": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "deploy": "powershell -ExecutionPolicy Bypass -File scripts/deploy.ps1"
  }
}
